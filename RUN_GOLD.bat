@echo off
chcp 65001 >nul
REM ============================================================
REM  RUN_GOLD.bat — اضغط عليه دبل-كليك ليعمل كل شيء:
REM    ينزّل آخر كود، يسحب داتا XAUUSDm الحقيقية من MT5،
REM    يشغّل الباك-تست، ويرفع النتيجة لبوابة الترقية.
REM  الشرط الوحيد: افتح MetaTrader 5 وسجّل دخول قبل التشغيل.
REM ============================================================
title Gold Bot - Backtest Runner
cd /d "%~dp0"

echo.
echo ============================================================
echo   [1/3]  تنزيل آخر كود من GitHub ...
echo ============================================================
git pull origin main
if errorlevel 1 (
  echo.
  echo تعذّر git pull — قد لا يكون هذا مجلد git. سنكمل بالموجود.
)

echo.
echo ============================================================
echo   [2/3]  إعداد الاتصال بالداشبورد ...
echo ============================================================
set "BACKEND_URL=https://mq5-production.up.railway.app"
set "API_KEY=mysecretkey123"
set "BACKTEST_TF=5min"
echo   جاهز.

echo.
echo ============================================================
echo   [3/3]  سحب الداتا + الباك-تست + الرفع ...
echo   (تأكد أن MetaTrader 5 مفتوح ومسجّل دخول)
echo ============================================================
cd /d "%~dp0backtesting\fastest_gold"
python export_mt5_m5.py --run

echo.
echo ============================================================
echo   خلص. اقرأ الأرقام في الأعلى:
echo     - السبريد الحقيقي (وسيط X نقطة)
echo     - قرار السكربت (APPROVED / REJECTED)
echo   صوّر هذه الشاشة وابعتها.
echo ============================================================
echo.
pause
